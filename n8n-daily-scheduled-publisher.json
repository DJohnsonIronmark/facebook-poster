      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [1100, 500],
      "id": "get-token-text",
      "name": "Get Token (Text)",
      "credentials": {
        "facebookGraphApi": {
          "id": "JAEtqLx2roZPZJ0G",
          "name": "Facebook Graph User"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v24.0/{{ $('Loop Over Posts').item.json.facebook_page_id }}/photos",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "access_token",
              "value": "={{ $json.access_token }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "url",
              "value": "={{ $('Loop Over Posts').item.json.media_url }}"
            },
            {
              "name": "message",
              "value": "={{ $('Loop Over Posts').item.json.post_content }}"
            },
            {
              "name": "published",
              "value": "true"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [1320, 100],
      "id": "publish-photo",
      "name": "Publish Photo"
